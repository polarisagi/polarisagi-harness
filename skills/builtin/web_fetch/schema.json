{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "url": { "type": "string", "format": "uri" },
    "method": { "type": "string", "default": "GET" },
    "headers": { "type": "object" },
    "body": { "type": "string" },
    "max_bytes": { "type": "integer", "default": 1048576 }
  },
  "required": ["url"]
}
