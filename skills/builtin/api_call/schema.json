{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "url": { "type": "string", "format": "uri" },
    "method": { "type": "string", "default": "GET" },
    "headers": { "type": "object" },
    "body": { "type": "string" },
    "auth_type": { "type": "string", "enum": ["none", "bearer", "basic", "api_key"] }
  },
  "required": ["url"]
}
